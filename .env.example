# SAFE-AI Excel 梳理小工具 - 環境變數設定
# 複製此檔案為 .env 並填入實際值

# PostgreSQL 密碼
POSTGRES_PASSWORD=safeai_secret

# JWT 密鑰 (生產環境請使用強隨機字串)
JWT_SECRET=your_jwt_secret_here

# Gemini API Key (用於 QA 問答對比模組)
GEMINI_API_KEY=your_gemini_api_key_here

# T3 TrustChain 平台 API URL
BLOCKCHAIN_API_URL=http://127.0.0.1:3000

# T3 平台 API Key (由 T3 Admin 建立平台時取得)
T3_API_KEY=your_t3_api_key_here
