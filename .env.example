# Database password (same for both backend and db container)
POSTGRES_PASSWORD=change_me_to_a_strong_password

# JWT secret for auth token signing (use a long random string)
JWT_SECRET=change_me_to_a_random_64_char_string

# Google Gemini API key (for QA module, optional)
GEMINI_API_KEY=

# Blockchain API URL (for evidence module, optional)
BLOCKCHAIN_API_URL=http://localhost:9000
